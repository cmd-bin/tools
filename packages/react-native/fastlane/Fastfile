# frozen_string_literal: true

opt_out_usage

require_relative 'utils/index'

DEFAULT_EXPORT_METHOD   = 'app-store'
XCODEBUILD_FORMATTER    = 'xcbeautify --renderer github-actions'

default_platform(:ios)

after_all do |_lane|
  File.write($pbxproj_path, $pbxproj_backup) if $pbxproj_path && $pbxproj_backup
  cleanup
end

error do |_lane, _exception|
  File.write($pbxproj_path, $pbxproj_backup) if $pbxproj_path && $pbxproj_backup
end

platform :ios do
  desc 'Push a new build to TestFlight'

  before_all do |lane|
    pre_script = ConfigHelper.optional_env('BEFORE_ALL', default: nil)
    sh(pre_script) if pre_script
    Dir.chdir(ENV['CALLER_WORKSPACE']) do
      # "npm ls" başarılıysa (0 dönerse) sistem zaten güncel demektir.
      ipc_client(event_name: 'Node modules are checking', payload: { id: 0, start: true })
      if system('npm ls > /dev/null 2>&1')
        ipc_client(event_name: 'Node modules are up to date', payload: { id: 0, end: true })
      else
        ipc_client(event_name: 'Node modules are installing', payload: { id: 0 })
        sh('npm ci')
        ipc_client(event_name: 'Node modules are installed', payload: { id: 0, end: true })
      end
    end
    if lane != :pod
      Dir.chdir(File.join(ENV['CALLER_WORKSPACE'], 'ios')) do
        ipc_client(event_name: 'Pods are checking', payload: { start: true })
        if system('cmp -s Podfile.lock Pods/Manifest.lock')
          ipc_client(event_name: 'Pods are up to date', payload: { end: true })
        else
          ipc_client(event_name: 'Pods are installing')
          sh('bundle exec pod install')
          ipc_client(event_name: 'Pods are installed', payload: { end: true })
        end
      end
    end
  end

  lane :pod do |options|
    setup(export_method: options[:export_method] || 'app-store')
    Dir.chdir(File.join(ENV['CALLER_WORKSPACE'], 'ios')) do
      update = options[:update] || false
      ipc_client(event_name: "Installing pods#{update ? ' with repo-update' : ''}")
      sh("bundle exec pod install #{update ? '--repo-update' : ''}")
    end
  end

  lane :internal do
    result        = setup(export_method: 'app-store')
    config        = result[:config]
    api_key       = result[:api_key]

    latest_testflight_build_number(
      api_key: api_key,
      app_identifier: config[:app_identifier],
      initial_build_number: 0
    )

    build_number = lane_context[:LATEST_TESTFLIGHT_BUILD_NUMBER] + 1
    increment_build_number(
      xcodeproj: config[:project],
      skip_info_plist: false,
      build_number: build_number
    )

    app_target   = result[:targets].find { |t| t[:bundle_id] == config[:app_identifier] }
    version      = get_version_number(xcodeproj: config[:project], target: app_target[:name])

    archive_result = ipc_wrapper(
      event_name: "Creating Archive: v#{version}(#{build_number})",
      end_event_name: "Created Archive: v#{version}(#{build_number})",
      action: proc do
        create_archive(export_method: config[:export_method])
      end
    )

    ipa_result = ipc_wrapper(
      event_name: "Creating IPA: v#{version}(#{build_number})",
      end_event_name: "Created IPA: v#{version}(#{build_number})",
      action: proc do
        create_ipa(
          export_method: config[:export_method],
          archive_path: archive_result[:archive_path]
        )
      end
    )

    FileHelper.zip_folder(
      input_dir_path: config[:lane_output_directory],
      output_path: config[:zip_asset_path]
    )

    File.open(ENV['GITHUB_ENV'], 'a') { |f| f.puts("RELEASE_ASSET_PATH=#{config[:zip_asset_path]}") } if ENV['GITHUB_ENV']

    release_notes = GithubHelper.release_notes(
      cliff: config[:cliff],
      platform: :ios,
      version: ipa_result[:version],
      build_number: ipa_result[:build_number],
      build_environment: config[:build_environment]
    )

    github_release = nil
    if ENV['GITHUB_TOKEN'] && !ENV['GITHUB_TOKEN'].empty?
      github_release = ipc_wrapper(
        event_name: 'Creating Github Release',
        end_event_name: 'Created Github Release',
        action: proc do
          GithubHelper.create_release(
            platform: :ios,
            build_environment: config[:build_environment],
            version: ipa_result[:version],
            build_number: ipa_result[:build_number],
            release_notes: release_notes,
            upload_assets: [config[:zip_asset_path]]
          )
        end,
        end_payload_proc: proc do |res|
          { url: res['html_url'] }
        end
      )
    end

    testflight_params = {
      ipa: ipa_result[:path],
      api_key: api_key,
      app_identifier: config[:app_identifier],
      # If set to true, the distribute_external option won't work and no build will be distributed to testers.
      # (You might want to use this option if you are using this action on CI and have to pay for 'minutes used' on your CI plan).
      # If set to true and a changelog is provided, it will partially wait for the build to appear on AppStore Connect
      # so the changelog can be set, and skip the remaining processing steps
      skip_waiting_for_build_processing: true,
      distribute_external: false
    }

    if config[:send_changelog_to_testflight]
      testflight_params[:changelog] = "#{release_notes}#{
        github_release.nil? ? '' : "\nGithub Release(#{github_release['id']}): #{github_release['html_url']}"
      }"
    end

    ipc_wrapper(
      event_name: 'Uploading to Testflight',
      end_event_name: 'Uploaded to Testflight',
      action: proc do
        upload_to_testflight(testflight_params)
      end
    )

    clean_build_artifacts if ENV['CI']
  end

  lane :adhoc do
    result  = setup(export_method: 'ad-hoc')
    config  = result[:config]
    FileHelper.decode_base64_to_file(
      config[:firebase_credentials_base64],
      config[:firebase_credentials_path]
    )

    latest_release = firebase_app_distribution_get_latest_release(
      app: config[:firebase_app_id],
      service_credentials_file: config[:firebase_credentials_path]
    )

    build_number = (latest_release&.[](:buildVersion).to_i || 0) + 1
    increment_build_number(
      xcodeproj: config[:project],
      skip_info_plist: false,
      build_number: build_number
    )

    app_target   = result[:targets].find { |t| t[:bundle_id] == config[:app_identifier] }
    version      = get_version_number(xcodeproj: config[:project], target: app_target[:name])

    archive_result = ipc_wrapper(
      event_name: "Creating Archive: v#{version}(#{build_number})",
      end_event_name: "Created Archive: v#{version}(#{build_number})",
      action: proc do
        create_archive(export_method: config[:export_method])
      end
    )

    ipa_result = ipc_wrapper(
      event_name: 'Creating IPA',
      end_event_name: 'Created IPA',
      action: proc do
        create_ipa(
          export_method: config[:export_method],
          archive_path: archive_result[:archive_path]
        )
      end
    )

    FileHelper.zip_folder(
      input_dir_path: config[:lane_output_directory],
      output_path: config[:zip_asset_path]
    )
    File.open(ENV['GITHUB_ENV'], 'a') { |f| f.puts("RELEASE_ASSET_PATH=#{config[:zip_asset_path]}") } if ENV['GITHUB_ENV']

    release_notes = GithubHelper.release_notes(
      cliff: config[:cliff],
      platform: :ios,
      version: ipa_result[:version],
      build_number: ipa_result[:build_number],
      build_environment: config[:build_environment]
    )

    github_release = nil
    if ENV['GITHUB_TOKEN'] && !ENV['GITHUB_TOKEN'].empty?
      github_release = ipc_wrapper(
        event_name: 'Creating Github Release',
        end_event_name: 'Created Github Release',
        action: proc do
          GithubHelper.create_release(
            platform: :ios,
            build_environment: config[:build_environment],
            version: ipa_result[:version],
            build_number: ipa_result[:build_number],
            release_notes: release_notes,
            upload_assets: [config[:zip_asset_path]]
          )
        end,
        end_payload_proc: proc do |res|
          { url: res['html_url'] }
        end
      )
    end

    release_notes_with_github = "#{release_notes.empty? ? '' : "#{release_notes}\n"}#{
      github_release.nil? ? '' : "Github Release(#{github_release['id']}): #{github_release['html_url']}"
    }"
    ipc_wrapper(
      event_name: 'Uploading to Firebase App Distribution',
      end_event_name: 'Uploaded to Firebase App Distribution',
      action: proc do
        firebase_app_distribution(
          app: config[:firebase_app_id],
          service_credentials_file: config[:firebase_credentials_path],
          groups: config[:firebase_tester_group],
          release_notes: release_notes_with_github,
          ipa_path: ipa_result[:path]
        )
      end,
      end_payload_proc: proc do |res|
        {
          download: res[:binaryDownloadUri],
          console: res[:firebaseConsoleUri],
          testing: res[:testingUri],
          createdAt: res[:createTime],
          updatedAt: res[:updateTime],
          expireAt: res[:expireTime],
          version: "#{res[:displayVersion]}(#{res[:buildVersion]})"
        }
      end
    )

    clean_build_artifacts if ENV['CI']
  end

  lane :create_archive do |options|
    result         = setup(export_method: options[:export_method] || DEFAULT_EXPORT_METHOD)
    targets        = result[:targets]
    config         = result[:config]
    archive_path   = options[:archive_path] || config[:xcarchive_path]

    app_target   = targets.find { |t| t[:bundle_id] == config[:app_identifier] }
    version      = get_version_number(xcodeproj: config[:project], target: app_target[:name])
    build_number = get_build_number(xcodeproj: config[:project])

    $pbxproj_path ||= File.join(config[:project], 'project.pbxproj')
    $pbxproj_backup ||= File.read($pbxproj_path)

    targets.each do |target|
      update_code_signing_settings(
        use_automatic_signing: false,
        team_id: config[:team_id],
        path: config[:project],
        bundle_identifier: target[:bundle_id],
        profile_name: target[:profile_name],
        profile_uuid: target[:profile_uuid],
        targets: target[:name],
        code_sign_identity: target[:cert_name]
      )
    end

    # Archive
    build_app(
      workspace: config[:workspace],
      scheme: config[:scheme],
      silent: config[:silent],
      configuration: config[:configuration],
      xcodebuild_formatter: XCODEBUILD_FORMATTER,
      archive_path: archive_path,
      derived_data_path: config[:derived_data_path],
      skip_profile_detection: true,
      skip_build_archive: false,
      skip_codesigning: false,
      skip_package_ipa: true,
      export_method: config[:export_method],
      export_team_id: config[:team_id],
      export_options: {
        method: config[:export_method],
        compile_bitcode: true,
        provisioningProfiles: targets.each_with_object({}) { |t, h| h[t[:bundle_id]] = t[:profile_uuid] }
      }
    )

    {
      version: version,
      build_number: build_number,
      archive_path: lane_context[SharedValues::XCODEBUILD_ARCHIVE]
    }
  end

  lane :create_ipa do |options|
    result       = setup(export_method: options[:export_method] || DEFAULT_EXPORT_METHOD)
    targets      = result[:targets]
    config       = result[:config]
    archive_path = options[:archive_path] || config[:xcarchive_path]
    output_dir   = options[:output_directory] || config[:ipa_output_directory]

    archive_info = Plist.parse_xml("#{archive_path}/Info.plist")
    app_props    = archive_info['ApplicationProperties']
    version      = app_props['CFBundleShortVersionString']
    build_number = app_props['CFBundleVersion']

    # Create IPA
    build_app(
      workspace: config[:workspace],
      scheme: config[:scheme],
      silent: config[:silent],
      configuration: config[:configuration],
      output_name: config[:scheme],
      xcodebuild_formatter: XCODEBUILD_FORMATTER,
      archive_path: archive_path,
      derived_data_path: config[:derived_data_path],
      output_directory: output_dir,
      skip_profile_detection: true,
      skip_build_archive: true,
      skip_codesigning: false,
      skip_package_ipa: false,
      export_method: config[:export_method],
      export_team_id: config[:team_id],
      export_options: {
        method: config[:export_method],
        compile_bitcode: true,
        provisioningProfiles: targets.each_with_object({}) { |t, h| h[t[:bundle_id]] = t[:profile_uuid] }
      }
    )

    {
      version: version,
      build_number: build_number,
      path: lane_context[SharedValues::IPA_OUTPUT_PATH]
    }
  end

  lane :resign_ipa do |options|
    result    = setup(export_method: options[:export_method] || DEFAULT_EXPORT_METHOD)
    targets   = result[:targets]
    cert_name = result[:cert_name]

    resign(
      ipa: options[:ipa_path],
      signing_identity: cert_name,
      provisioning_profile: targets.each_with_object({}) { |t, h| h[t[:bundle_id]] = t[:profile_path] }
    )
  end
end

platform :android do
  desc 'Push a new build to Firebase App Distribution'

  before_all do
    pre_script = ConfigHelper.optional_env('BEFORE_ALL', default: nil)
    sh(pre_script) if pre_script
    Dir.chdir(ENV['CALLER_WORKSPACE']) do
      # "npm ls" başarılıysa (0 dönerse) sistem zaten güncel demektir.
      ipc_client(event_name: 'Node modules are checking', payload: { id: 0, start: true })
      if system('npm ls > /dev/null 2>&1')
        ipc_client(event_name: 'Node modules are up to date', payload: { id: 0, end: true })
      else
        ipc_client(event_name: 'Node modules are installing', payload: { id: 0 })
        sh('npm ci')
        ipc_client(event_name: 'Node modules are installed', payload: { id: 0, end: true })
      end
    end
  end

  lane :internal do |options|
    result        = setup(export_method: options[:export_method] || 'aab')
    config        = result[:config]
    version_name  = android_get_version_name(gradle_file: config[:app_gradle_file_path])

    version_codes = google_play_track_version_codes(
      package_name: config[:app_identifier],
      track: 'internal',
      json_key: config[:play_store_credentials_path]
    )

    latest_build_number = version_codes.empty? ? 0 : version_codes.first
    new_build_number = latest_build_number + 1

    android_set_version_code(
      version_code: new_build_number,
      gradle_file: config[:app_gradle_file_path]
    )
    ipc_wrapper(
      event_name: "Building: v#{version_name}(#{new_build_number})",
      end_event_name: "Build: v#{version_name}(#{new_build_number})",
      payload: { id: 2 },
      action: proc do
        create_bundle(export_method: config[:export_method])
      end
    )

    apk_path = lane_context[SharedValues::GRADLE_APK_OUTPUT_PATH]
    aab_path = lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH]

    FileHelper.zip_folder(
      input_dir_path: config[:export_method] == 'apk' ? File.dirname(apk_path) : File.dirname(aab_path),
      output_path: config[:zip_asset_path]
    )

    File.open(ENV['GITHUB_ENV'], 'a') { |f| f.puts("RELEASE_ASSET_PATH=#{config[:zip_asset_path]}") } if ENV['GITHUB_ENV']

    release_notes = GithubHelper.release_notes(
      cliff: config[:cliff],
      platform: :android,
      version: version_name,
      build_number: new_build_number,
      build_environment: config[:build_environment]
    )

    if ENV['GITHUB_TOKEN'] && !ENV['GITHUB_TOKEN'].empty?
      ipc_wrapper(
        event_name: 'Creating Github Release',
        end_event_name: 'Created Github Release',
        payload: { id: 3 },
        action: proc do
          GithubHelper.create_release(
            build_environment: config[:build_environment],
            platform: :android,
            version: version_name,
            build_number: new_build_number,
            release_notes: release_notes,
            upload_assets: [config[:zip_asset_path]]
          )
        end,
        end_payload_proc: proc { |res| { url: res['html_url'] } }
      )
    end

    play_store_params = {
      package_name: config[:app_identifier],
      track: config[:play_store_track],
      release_status: config[:play_store_release_status],
      json_key: config[:play_store_credentials_path]
    }

    if config[:export_method] == 'apk'
      play_store_params[:apk] = apk_path
      play_store_params[:skip_upload_aab] = true
    else
      play_store_params[:aab] = aab_path
      play_store_params[:skip_upload_apk] = true
    end

    ipc_wrapper(
      event_name: 'Uploading to Play Store',
      end_event_name: 'Uploaded to Play Store',
      payload: { id: 4 },
      action: proc do
        upload_to_play_store(play_store_params)
      end
    )
  end

  lane :adhoc do |options|
    result        = setup(export_method: options[:export_method] || 'apk')
    config        = result[:config]
    FileHelper.decode_base64_to_file(
      config[:firebase_credentials_base64],
      config[:firebase_credentials_path]
    )

    version_name = android_get_version_name(gradle_file: config[:app_gradle_file_path])

    latest_release = firebase_app_distribution_get_latest_release(
      app: config[:firebase_app_id],
      service_credentials_file: config[:firebase_credentials_path]
    )

    new_build_number = (latest_release&.[](:buildVersion).to_i || 0) + 1

    android_set_version_code(
      version_code: new_build_number,
      gradle_file: config[:app_gradle_file_path]
    )

    ipc_wrapper(
      event_name: "Building: v#{version_name}(#{new_build_number})",
      end_event_name: "Build: v#{version_name}(#{new_build_number})",
      payload: { id: 2 },
      action: proc do
        create_bundle(export_method: config[:export_method])
      end
    )

    apk_path = lane_context[SharedValues::GRADLE_APK_OUTPUT_PATH]
    aab_path = lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH]

    FileHelper.zip_folder(
      input_dir_path: config[:export_method] == 'apk' ? File.dirname(apk_path) : File.dirname(aab_path),
      output_path: config[:zip_asset_path]
    )
    File.open(ENV['GITHUB_ENV'], 'a') { |f| f.puts("RELEASE_ASSET_PATH=#{config[:zip_asset_path]}") } if ENV['GITHUB_ENV']

    release_notes = GithubHelper.release_notes(
      cliff: config[:cliff],
      platform: :android,
      version: version_name,
      build_number: new_build_number,
      build_environment: config[:build_environment]
    )

    # github_release = nil
    if ENV['GITHUB_TOKEN'] && !ENV['GITHUB_TOKEN'].empty?
      github_release = ipc_wrapper(
        event_name: 'Creating Github Release',
        end_event_name: 'Created Github Release',
        payload: { id: 3 },
        action: proc do
          GithubHelper.create_release(
            build_environment: config[:build_environment],
            platform: :android,
            version: version_name,
            build_number: new_build_number,
            release_notes: release_notes,
            upload_assets: [config[:zip_asset_path]]
          )
        end,
        end_payload_proc: proc { |res| { url: res['html_url'] } }
      )
    end

    release_notes_with_github = "#{release_notes.empty? ? '' : "#{release_notes}\n"}#{
      github_release.nil? ? '' : "Github Release(#{github_release['id']}): #{github_release['html_url']}"
    }"

    firebase_app_distribution_params = {
      app: config[:firebase_app_id],
      service_credentials_file: config[:firebase_credentials_path],
      groups: config[:firebase_tester_group],
      release_notes: release_notes_with_github
    }

    if config[:export_method] == 'apk'
      firebase_app_distribution_params[:android_artifact_type] = 'APK'
      firebase_app_distribution_params[:android_artifact_path] = apk_path
    else
      firebase_app_distribution_params[:android_artifact_type] = 'AAB'
      firebase_app_distribution_params[:android_artifact_path] = aab_path
    end
    ipc_wrapper(
      event_name: 'Uploading to Firebase App Distribution',
      end_event_name: 'Uploaded to Firebase App Distribution',
      payload: { id: 4 },
      action: proc do
        firebase_app_distribution(firebase_app_distribution_params)
      end,
      end_payload_proc: proc do |res|
        {
          download: res[:binaryDownloadUri],
          console: res[:firebaseConsoleUri],
          testing: res[:testingUri],
          createdAt: res[:createTime],
          updatedAt: res[:updateTime],
          expireAt: res[:expireTime],
          version: "#{res[:displayVersion]}(#{res[:buildVersion]})"
        }
      end
    )
  end

  lane :create_bundle do |options|
    result        = setup(export_method: options[:export_method] || 'aab')
    config        = result[:config]

    gradle(
      task: config[:task],
      build_type: config[:build_type],
      print_command: false,
      project_dir: config[:project_dir],
      gradle_path: config[:gradle_path],
      flags: '--build-cache --no-daemon',
      properties: {
        'android.injected.signing.store.file' => config[:key_store_path],
        'android.injected.signing.store.password' => config[:key_store_password],
        'android.injected.signing.key.alias' => config[:key_alias],
        'android.injected.signing.key.password' => config[:key_password]
      },
      system_properties: {
        'org.gradle.caching' => 'true',
        'org.gradle.parallel' => 'true',
        'org.gradle.jvmargs' => '-Xmx8192m -XX:MaxMetaspaceSize=4096m'
      }
    )
    ipc_client(event_name: "Created #{config[:export_method].upcase} file")
  end
end

desc 'Sync certificates and provisioning profiles'
lane :match_sync do |options|
  FileHelper.read_env(env_path: options[:env_path] || File.join(ENV['GITHUB_WORKSPACE'], '.env.deploy'))
  puts "env file is loaded: #{ENV['APPLE_KEY_ID']}"
  generate_apple_certs = options[:generate].to_s.strip.downcase == 'true'
  force = options[:force].to_s.strip.downcase == 'true'
  force_for_new_devices = options[:force_for_new_devices].to_s.strip.downcase == 'true'

  api_key = app_store_connect_api_key(
    key_id: ENV['APPLE_KEY_ID'],
    issuer_id: ENV['APPLE_ISSUER_ID'],
    is_key_content_base64: true,
    key_content: ENV['APPLE_KEY'],
    in_house: options[:in_house] || false
  )

  app_identifier = (options[:app_identifier] || ENV['APP_IDENTIFIER'])&.split(',')&.map(&:strip)

  match_options = {
    # Profile type to sync. Docs default: "development".
    type: options[:type] || 'development',
    # Extra cert types for macOS installers. Docs default: nil.
    additional_cert_types: nil,
    # Fetch only; do not create new certs/profiles. Docs default: false.
    readonly: false,
    # Create Apple Development/Distribution certs on supported Xcode/macOS setups.
    generate_apple_certs: generate_apple_certs,
    # Skip provisioning profile sync entirely. Docs default: false.
    skip_provisioning_profiles: false,
    # Bundle identifiers as comma-separated string or array. Docs default: Appfile app_identifier.
    app_identifier: app_identifier,

    # Path to App Store Connect API key JSON. Docs default: nil.
    api_key_path: nil,
    # App Store Connect API key hash. Docs default: nil.
    api_key: api_key,
    # Apple ID username. Docs default: Appfile apple_dev_portal_id/apple_id.
    # username: ENV["MATCH_REPO_USERNAME"],
    # Developer Portal team id. Docs default: Appfile team_id.
    team_id: ENV['APPLE_DEVELOPER_PORTAL_TEAM_ID'],
    # Developer Portal team name. Docs default: Appfile team_name.
    team_name: nil,

    # Storage backend. Docs default: "git".
    storage_mode: 'git',
    # Git repo URL that stores certificates. Required for git storage.
    git_url: ENV['MATCH_REPO_URL'],
    # Git branch to use. Docs default: "master".
    git_branch: ENV['MATCH_REPO_BRANCH'],
    # Git commit author name. Docs default: nil.
    git_full_name: 'NF Fastlane',
    # Git commit author email. Docs default: nil.
    git_user_email: ENV['MATCH_REPO_USERNAME'],
    # Clone only the latest revision. Docs default: false.
    shallow_clone: false,
    # Clone only the target branch. Docs default: false.
    clone_branch_directly: true,
    # Base64 basic auth header for git access. Docs default: nil.
    git_basic_authorization: nil,
    # Base64 bearer auth header for git access. Docs default: nil.
    git_bearer_authorization: nil,
    # Deploy key path/content for git access. Docs Default: nil.
    git_private_key: FileHelper.decode_base64(ENV['MATCH_REPO_PRIVATE_KEY']),

    # Keychain to import certificates into. Docs default: "login.keychain".
    keychain_name: 'login.keychain',
    # Keychain password, usually needed on new machines. Docs default: nil.
    keychain_password: nil,

    # Always renew provisioning profiles. Docs default: false.
    force: force,
    # Renew profiles when enabled device count changes. Docs default: false.
    force_for_new_devices: force_for_new_devices,
    # Include Apple Silicon Macs in iOS/iPadOS profiles. Docs default: false.
    include_mac_in_profiles: false,
    # Include all matching certs in development profiles. Docs default: false.
    include_all_certificates: false,
    # Force a specific certificate id. Docs default: nil.
    certificate_id: nil,
    # Renew profiles when certificate count changes. Docs default: false.
    force_for_new_certificates: false,
    # Auto-confirm destructive prompts. Docs default: false.
    skip_confirmation: false,
    # During nuke, remove from repo without revoking on portal. Docs default: false.
    safe_remove_certs: false,
    # Skip README generation in the cert repo. Docs default: false.
    skip_docs: false,
    # Provisioning profile platform. Docs default: current lane platform or "ios".
    platform: 'ios',
    # Prefix Mac Catalyst identifiers for old Xcode projects. Docs default: false.
    derive_catalyst_app_identifier: false,
    # Deprecated managed capabilities template name. Docs default: nil.
    template_name: nil,
    # Custom provisioning profile name. Docs default: nil.
    profile_name: nil,
    # Fail if a duplicate profile name would be created. Docs default: false.
    fail_on_name_taken: false,
    # Skip certificate matching; only for import flows. Docs default: false.
    skip_certificate_matching: false,
    # Export certs/keys/profiles to a path. Docs default: nil.
    output_path: nil,
    # Skip key partition list setup. Docs default: false.
    skip_set_partition_list: false,
    # Use legacy CBC encryption for backwards compatibility. Docs default: false.
    force_legacy_encryption: false,
    # Print verbose logs and commands. Docs default: false.
    verbose: false
  }

  match(match_options.compact)
end
