# frozen_string_literal: true

opt_out_usage

require_relative "utils/config_helper"
require_relative "utils/file_helper"
require_relative "utils/github_helper"
require_relative "utils/ipc_client"

default_platform(:ios)
$setup_ios_result = nil
$setup_android_result = nil

platform :ios do
  desc "Setup for iOS"

  lane :setup do |options|
    next $setup_ios_result unless $setup_ios_result.nil?

    config = ConfigHelper.platform_config(platform: :ios, export_method: options[:export_method], is_ci: is_ci)
    setup_ci if ENV['CI']
    clear_derived_data if ENV["CI"]
    match_type = config[:match_type]

    IpcClient.send_event("Loading Targets")
    target_identifier_map = Xcodeproj::Project.open(config[:project]).native_targets.map do |target|
      bundle_id = target.build_configurations.first.build_settings["PRODUCT_BUNDLE_IDENTIFIER"]
      { name: target.name, bundle_id: bundle_id }
    end

    IpcClient.send_event("Got Apple Developer account")
    api_key = app_store_connect_api_key(
      key_id: config[:key_id],
      issuer_id: config[:issuer_id],
      is_key_content_base64: false,
      key_filepath: config[:key_filepath],
      in_house: config[:in_house]
    )

    IpcClient.send_event("Matching certificates")
    match(
      type: match_type,
      app_identifier: target_identifier_map.map { |t| t[:bundle_id] },
      username: config[:match_username],
      clone_branch_directly: true,
      storage_mode: "git",
      git_url: config[:match_git_url],
      git_branch: config[:match_git_branch],
      api_key: api_key,
      readonly: config[:match_readonly],
      git_private_key: FileHelper.decode_base64(config[:match_git_private_key_base64])
    )

    cert_name = ENV["sigh_#{config[:app_identifier]}_#{match_type}_certificate-name"]
    targets = target_identifier_map.map do |target|
      bid = target[:bundle_id]
      {
        name: target[:name],
        bundle_id: bid,
        profile_uuid: ENV["sigh_#{bid}_#{match_type}"],
        profile_name: ENV["sigh_#{bid}_#{match_type}_profile-name"],
        profile_path: ENV["sigh_#{bid}_#{match_type}_profile-path"],
        cert_name: cert_name
      }
    end

    IpcClient.send_event("Setup Completed")

    $setup_ios_result = {
      config: config,
      api_key: api_key,
      targets: targets,
      cert_name: cert_name
    }
  end
end

platform :android do
  desc "Setup for Android"

  lane :setup do |options|
    next $setup_android_result unless $setup_android_result.nil?

    config = ConfigHelper.platform_config(platform: :android, export_method: options[:export_method], is_ci: is_ci)

    IpcClient.send_event("Setup Completed")

    $setup_android_result = {
      config: config
    }
  end
end